kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent:
    displayName: Popola Menu Giornaliero
    triggerQueries:
      - POPOLA_MENU_GIORNALIERO

  actions:
    - kind: SetVariable
      id: setDataOggi
      variable: Topic.DataOggi
      value: =Text(Today(), "yyyy-MM-dd")

    - kind: SetVariable
      id: setQueryMenu
      variable: Topic.QueryMenu
      value: Quali sono i piatti del menu di La Flaca? Elencali tutti separati da virgola, solo i nomi senza descrizioni.

    - kind: InvokeFlowAction
      id: cancellaMenuOggi
      input:
        binding:
          text: =Topic.DataOggi
        text: =Topic.DataOggi
      output: {}
      flowId: af9651ee-3975-f111-ab0d-7c1e52357019

    - kind: SearchAndSummarizeContent
      id: getMenuPrimi
      variable: Topic.RawPrimi
      userInput: =Topic.QueryMenu
      knowledgeSources:
        kind: SearchSpecificKnowledgeSources
        knowledgeSources:
          - ddo_SLCEFlacaAgent.topic.httpswwwlaflacaromaitprimi_wX3jmGEJDYF0BLBJDEtoI

    - kind: SetVariable
      id: cleanPrimi
      variable: Topic.Primi
      value: =Trim(First(Split(First(Split(Topic.RawPrimi, Char(10)&Char(10))).Value, " [")).Value)

    - kind: ConditionGroup
      id: checkPrimi
      conditions:
        - id: hasPrimi
          condition: =!IsBlank(Topic.Primi)
          actions:
            - kind: InvokeFlowAction
              id: scriviPrimi
              input:
                binding:
                  text: =Topic.Primi
                  text_1: =Topic.DataOggi
                  text_2: Primi
                text: =Topic.Primi
                text_1: =Topic.DataOggi
                text_2: Primi
              output: {}
              flowId: 0c130643-6872-f111-ab0d-000d3a693112

