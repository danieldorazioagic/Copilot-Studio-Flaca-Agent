kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent:
    displayName: Raccolta Ordini
    triggerQueries:
      - ordino
      - voglio ordinare
      - scelgo
      - prendo
      - vorrei
      - mi segni

  actions:
    - kind: SetVariable
      id: setDataOggi
      variable: Topic.DataOggi
      value: =Text(Today(), "yyyy-MM-dd")

    - kind: SetVariable
      id: setUPN
      variable: Topic.UtenteUPN
      value: =System.User.PrincipalName

    - kind: SetVariable
      id: setOraLocale
      variable: Topic.OraLocale
      value: =Hour(DateAdd(Now(), 2, TimeUnit.Hours))

    - kind: SetVariable
      id: initNomePiatto
      variable: Topic.NomePiatto
      value: =Text("")

    - kind: SetVariable
      id: initNumeroPiatto
      variable: Topic.NumeroPiatto
      value: "0"

    - kind: SetVariable
      id: initNumeroPiattoInt
      variable: Topic.NumeroPiattoInt
      value: =0

    - kind: SetVariable
      id: initInputOrdine
      variable: Topic.InputOrdine
      value: =Text("")

    - kind: ConditionGroup
      id: gateOrario
      conditions:
        - id: orarioValido
          condition: =And(Topic.OraLocale >= 10, Topic.OraLocale < 12)
          actions:
            - kind: Question
              id: askPiatto
              alwaysPrompt: true
              variable: Topic.InputOrdine
              prompt:
                activity:
                  text: Scrivi il numero o il nome del piatto che vuoi ordinare.

              entity: StringPrebuiltEntity

            - kind: InvokeFlowAction
              id: callValidaOrdine
              input:
                binding:
                  text: =Topic.InputOrdine

                text: =Topic.InputOrdine

              output:
                binding:
                  text: Topic.NomePiatto
                  text_1: Topic.NumeroPiatto

              flowId: cbbc79f7-2076-f111-ab0d-7c1e52357b26

            - kind: SetVariable
              id: normalizzaNomePiatto
              variable: Topic.NomePiatto
              value: =Concatenate(Topic.NomePiatto, "")

            - kind: ConditionGroup
              id: checkTrovato
              conditions:
                - id: piattoTrovato
                  condition: =!IsBlank(Topic.NomePiatto)
                  actions:
                    - kind: SetVariable
                      id: setNumeroPiattoInt
                      variable: Topic.NumeroPiattoInt
                      value: =Value(Topic.NumeroPiatto)

                    - kind: InvokeFlowAction
                      id: callRegistraOrdine
                      input:
                        binding:
                          number: =Topic.NumeroPiattoInt
                          text: =Topic.UtenteUPN
                          text_1: =Topic.NomePiatto

                        number: =Topic.NumeroPiattoInt
                        text: =Topic.UtenteUPN
                        text_1: =Topic.NomePiatto

                      output: {}
                      flowId: 470a3e38-1b76-f111-ab0d-7c1e52357b26

                    - kind: SendActivity
                      id: msgConferma
                      activity: Registazione effettuata con successo

                - id: piattoNonTrovato
                  condition: =IsBlank(Topic.NomePiatto)
                  actions:
                    - kind: SendActivity
                      id: msgPiattoNonTrovato
                      activity: Nome piatto non valorizzato

        - id: troppoPresto
          condition: =Topic.OraLocale < 10
          actions:
            - kind: SendActivity
              id: msgTroppoPresto
              activity: Hai fame? è presto per ordinare, aspetta le 10

        - id: troppoTardi
          condition: =Topic.OraLocale >= 12
          actions:
            - kind: SendActivity
              id: msgTroppoTardi
              activity: "Mi dispiace ma se stato lento, ordina entro le 12 la prossima volta "

inputType: {}
outputType: {}